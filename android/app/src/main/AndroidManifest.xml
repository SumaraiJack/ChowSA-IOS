<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Notification & Alarm permissions ────────────────────────────────
         POST_NOTIFICATIONS  (Android 13+ / API 33): runtime prompt for
                             showing notifications. Without this the
                             runtime dialog never fires and the OS silently
                             blocks all scheduled notifications.

         SCHEDULE_EXACT_ALARM (Android 12+ / API 31): required by
                             flutter_local_notifications' zonedSchedule()
                             with AndroidScheduleMode.exactAllowWhileIdle.
                             Declaring it in the manifest makes the app
                             appear on the "Alarms and reminders" system
                             Settings page so the user can flip the toggle.
                             Without this line the toggle page shows
                             "Restricted" / greyed out.

         USE_EXACT_ALARM     (Android 14+ / API 34): non-revocable sibling
                             for apps whose core function is alarms/timers.
                             Declared as a fallback — the system grants
                             whichever one the API level requires.         -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Location — used by LocalHubService to resolve the user's nearest
         community hub via the Supabase `get_nearest_hubs` PostGIS RPC, and
         by LoadsheddingService for province/suburb detection. COARSE is
         sufficient for suburb-level resolution; FINE is requested as the
         preferred tier on devices that grant it. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Network — Supabase + Gemini + Play Store rate flow. Implicit on
         older API levels but required to be declared explicitly so the
         Play Console pre-launch report doesn't flag missing internet. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:label="ChowSA"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Supabase deep-link: handles email confirmation redirects -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="io.supabase.chowsa"/>
            </intent-filter>
            <!-- FCM notification taps. Routes system-tray taps (app
                 backgrounded OR killed) into MainActivity so
                 FirebaseMessaging.onMessageOpenedApp / getInitialMessage()
                 fire with the RemoteMessage payload. -->
            <intent-filter>
                <action android:name="FLUTTER_NOTIFICATION_CLICK"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <!-- ── FCM defaults ──────────────────────────────────────────────
             Tells the FCM SDK which channel to post into when a remote
             "notification" payload arrives WITHOUT a channel id (i.e. sent
             from the Notifications composer or older Edge Function payloads).
             Must match the channel id created in NotificationService. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="chowsa_default" />
        <!-- Monochrome status-bar silhouette. Coloured launcher icons get
             rendered as a solid white square on Android 5+, which is what
             made push notifications look broken before this change. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notification" />
        <!-- Forest-green tint for the silhouette so the status bar isn't
             plain white on coloured wallpapers. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_tint" />

        <!-- Google Mobile Ads (AdMob) App ID — injected at build time from
             android/app/build.gradle.kts via the manifestPlaceholder
             `admobAppId`. The Gradle script reads the `IS_PRODUCTION`
             project property and picks the test or production ID, mirroring
             the Dart-side EnvConfig.isProduction switch so the native and
             Flutter layers can never drift apart. See env_config.dart. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${admobAppId}"/>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- ── Package visibility queries (Android 11+ / API 30+) ─────────────
         Android 11 introduced strict package visibility — apps can no
         longer enumerate installed packages without declaring their
         intent. url_launcher's canLaunchUrl() silently returns false for
         every scheme not listed here. ChowSA opens four kinds of URLs:

           1. mailto:    — Help & Feedback support email
           2. tel:       — future support number; declared pre-emptively
           3. https:     — Play Store web fallback, recipe scraper, etc.
           4. market:    — native Play Store deep-link for Rate ChowSA
           5. geo:       — native maps intent for Spotted location pins

         Plus the Flutter engine's PROCESS_TEXT query that ships in the
         template — needed by the engine itself, don't drop it.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="mailto"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="market"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="geo"/>
        </intent>
    </queries>
</manifest>
