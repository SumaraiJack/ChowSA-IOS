<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground>
        <inset
            android:drawable="@drawable/ic_launcher_foreground"
            android:inset="16%" />
    </foreground>
    <!--
        Android 13+ themed-icon layer. When the user enables "Themed icons"
        in their launcher, Android tints THIS drawable with the device's
        Material You / wallpaper-derived monochrome scheme. Using the same
        notification silhouette here gives ChowSA a coherent monochrome
        identity in that mode without needing a separate asset.
    -->
    <monochrome android:drawable="@drawable/ic_stat_notification" />
</adaptive-icon>
