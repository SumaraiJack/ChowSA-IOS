<?xml version="1.0" encoding="utf-8"?>
<!--
  ChowSA notification small-icon.

  Android status-bar icons MUST be monochrome silhouettes (white shapes on
  transparent). Anything else — including coloured launcher icons — gets
  rendered as a solid white square on the lock screen and status bar. This
  vector is the fork+spoon "restaurant" mark in Material Symbols, sized to
  the standard 24dp notification canvas.

  Wired in AndroidManifest.xml via
    meta-data: com.google.firebase.messaging.default_notification_icon
  and in NotificationService.dart via the AndroidNotificationDetails.icon
  field, both pointing at @drawable/ic_stat_notification.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#FFFFFF">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M11,9H9V2H7v7H5V2H3v7c0,2.12 1.66,3.84 3.75,3.97V22h2.5v-9.03C11.34,12.84 13,11.12 13,9V2h-2V9zM16,6v8h2.5v8H21V2C18.24,2 16,4.24 16,6z"/>
</vector>
